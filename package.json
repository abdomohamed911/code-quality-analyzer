{
  "name": "code-quality-analyzer",
  "version": "1.1.0",
  "description": "CLI tool for static JavaScript code analysis — evaluates complexity, naming conventions, error handling, and documentation coverage",
  "main": "src/index.js",
  "bin": {
    "code-quality-analyzer": "./src/index.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "analyze": "node src/index.js analyze",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "code-quality",
    "static-analysis",
    "code-review",
    "complexity",
    "naming-conventions",
    "javascript",
    "cli"
  ],
  "author": "Abdelrahman Mohamed",
  "license": "MIT",
  "dependencies": {
    "acorn": "^8.11.0",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
